# OpenAI API (required for production embeddings and chat)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API (optional for pdf ingestion)
GOOGLE_API_KEY=your_openai_api_key_here

# Pinecone API (optional, for cloud vector storage)
PINECONE_API_KEY=your_pinecone_api_key_here

# Optional: Custom model endpoints
CUSTOM_EMBEDDING_ENDPOINT=
CUSTOM_LLM_ENDPOINT=

# Optional: Logging level
LOG_LEVEL=INFO

# Optional: Working directory paths
RAG_WORKING_DIR=./working_dir
RAG_VECTOR_DB_PATH=./vector_db